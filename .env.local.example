# ─── Inngest Swag Store Demo — Local Environment ──────────────────────────
# Copy to .env.local and fill in real values before running locally.
# .env.local is gitignored. Never commit real keys.

# ─── Stripe (test mode) ────────────────────────────────────────────────────
# Get these from Stripe Dashboard → Developers → API keys (test mode)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Get this by running `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# The CLI prints a fresh `whsec_...` each time it starts.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ─── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Inngest ──────────────────────────────────────────────────────────────
# INNGEST_DEV=1 routes the SDK to the local dev server (npx inngest-cli@latest dev).
# Without it, the SDK demands a signing key and 500s on /api/inngest.
INNGEST_DEV=1

# Production only — leave commented for local dev.
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# Encryption key for @inngest/middleware-encryption. Encrypts step output,
# function output, and event.data.encrypted before they hit Inngest's storage.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INNGEST_ENCRYPTION_KEY=REPLACE_ME

# ─── Demo backend (Railway Postgres) ──────────────────────────────────────
# Planned demo system of record. The current code still uses Google Sheets
# until the Postgres migration lands.
# DATABASE_URL=postgresql://user:password@host:port/railway
# DEMO_RESET_SECRET=replace-me

# ─── Legacy Google Sheets (orders fulfillment store) ──────────────────────
# Local dev: point at the SA key file.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/swag-store-sheets-key.json
# Production (Vercel etc.): set base64 of the key JSON instead, leave the
# path env var unset.
# GOOGLE_SERVICE_ACCOUNT_JSON=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50...

ORDERS_SHEET_ID=REPLACE_ME
ORDERS_SHEET_NAME=Sheet1
